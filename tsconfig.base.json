{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "strictPropertyInitialization": false,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@payroll/contracts": ["libs/contracts/src/index.ts"],
      "@payroll/event-bus": ["libs/event-bus/src/index.ts"],
      "@payroll/shared-kernel": ["libs/shared-kernel/src/index.ts"],
      "@payroll/testing": ["libs/testing/src/index.ts"],
      "@payroll/service-foundation": ["libs/service-foundation/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp", "dist"]
}
